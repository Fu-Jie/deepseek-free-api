# DeepSeek userToken，多个 token 用英文逗号分隔。
# 只填写 token 本体，不要加 Bearer。
DEEP_SEEK_CHAT_AUTHORIZATION=your_deepseek_user_token

# 可选：覆盖服务端口。
# SERVER_PORT=8000

# 可选：为 Anthropic/Claude Code 适配启用 DeepSeek 会话复用。
# 开启后会把同一 Claude 会话映射到同一 DeepSeek conversation_id，减少每轮全量历史重放。
# ANTHROPIC_SESSION_REUSE=true

# 可选：Anthropic 会话复用缓存 TTL，单位毫秒，默认 2 小时。
# ANTHROPIC_SESSION_TTL=7200000

# 可选：OpenAI Responses/Codex CLI 适配默认启用 DeepSeek 会话复用。
# 开启后会把 previous_response_id 映射到 DeepSeek conversation_id。如需关闭可设为 false。
# RESPONSES_SESSION_REUSE=true

# 可选：Responses 会话复用缓存 TTL，单位毫秒，默认 2 小时。
# RESPONSES_SESSION_TTL=7200000
